{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.45.0"
  },
  "schemaVersion": 19,
  "id": "get-payment-details",
  "versionTag": "2",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_payment",
      "text": "## Payment Details\nYour order total is shown below. Select your payment method to continue."
    },
    {
      "type": "text",
      "id": "finance_declined_notice",
      "text": "⚠️ **Finance application was declined:** {{declineReason}}. Please select an alternative payment method.",
      "conditional": {
        "hide": "=declineReason = null or declineReason = \"\""
      }
    },
    {
      "label": "Original Price (£)",
      "type": "number",
      "id": "totalAmount",
      "key": "totalAmount",
      "validate": {
        "required": true
      },
      "disabled": true
    },
    {
      "label": "Trade Card Discount Applied (£)",
      "type": "number",
      "id": "discountAmount",
      "key": "discountAmount",
      "description": "10% loyalty discount for verified Trade Card members.",
      "disabled": true,
      "conditional": {
        "hide": "=discountAmount = 0 or discountAmount = null"
      }
    },
    {
      "label": "Payment Method",
      "values": [
        {
          "label": "Cash",
          "value": "cash"
        },
        {
          "label": "Card",
          "value": "card"
        },
        {
          "label": "Interest-Free Finance (Trade Card members only)",
          "value": "finance"
        }
      ],
      "type": "select",
      "id": "paymentMethod",
      "key": "paymentMethod",
      "validate": {
        "required": true
      }
    },
    {
      "type": "text",
      "id": "section_card",
      "text": "#### Card Payment",
      "conditional": {
        "hide": "=paymentMethod != \"card\""
      }
    },
    {
      "label": "Card Number (last 4 digits)",
      "type": "textfield",
      "id": "cardNumber",
      "key": "cardNumber",
      "description": "Enter the last 4 digits of your payment card only.",
      "validate": {
        "required": true,
        "pattern": "^[0-9]{4}$"
      },
      "conditional": {
        "hide": "=paymentMethod != \"card\""
      }
    },
    {
      "type": "text",
      "id": "section_finance",
      "text": "#### Finance Payment Details\nInterest-free finance is available to Trade Card members only. Your trade card number is shown below.",
      "conditional": {
        "hide": "=paymentMethod != \"finance\""
      }
    },
    {
      "label": "Trade Card Number",
      "type": "textfield",
      "id": "tradeCardNumber",
      "key": "tradeCardNumber",
      "description": "Confirmed from your customer information.",
      "disabled": true,
      "conditional": {
        "hide": "=paymentMethod != \"finance\""
      }
    },
    {
      "label": "Repayment Period",
      "values": [
        {
          "label": "6 Months",
          "value": "6"
        },
        {
          "label": "12 Months",
          "value": "12"
        }
      ],
      "type": "radio",
      "id": "Field_0d26qit",
      "key": "repaymentPeriod",
      "validate": {
        "required": true
      },
      "conditional": {
        "hide": "=paymentMethod != \"finance\""
      }
    },
    {
      "label": "I confirm I am applying for interest-free finance and agree to the repayment schedule",
      "type": "checkbox",
      "id": "Field_1l0pduu",
      "key": "financeConfirmed",
      "validate": {
        "required": true
      },
      "conditional": {
        "hide": "=paymentMethod != \"finance\""
      }
    }
  ]
}
