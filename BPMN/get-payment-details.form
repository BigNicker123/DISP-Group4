{
  "components": [
    {
      "label": "Total Amount (£)",
      "type": "number",
      "id": "totalAmount",
      "key": "totalAmount",
      "validate": {
        "required": true
      },
      "disabled": true,
      "layout": {
        "row": "Row_0hkiatk"
      }
    },
    {
      "label": "Payment Method",
      "values": [
        {
          "label": "Cash",
          "value": "cash"
        },
        {
          "label": "Card",
          "value": "card"
        },
        {
          "label": "Interest-Free Finance (Trade Card members only)",
          "value": "finance"
        }
      ],
      "type": "select",
      "id": "paymentMethod",
      "key": "paymentMethod",
      "validate": {
        "required": true
      },
      "layout": {
        "row": "Row_1fzgf3e"
      }
    },
    {
      "label": "Card Number (last 4 digits)",
      "type": "textfield",
      "id": "cardNumber",
      "key": "cardNumber",
      "validate": {
        "required": false,
        "pattern": "\"^\\\\d{4}$\"",
        "patternErrorMessage": "Enter the last 4 digits"
      },
      "layout": {
        "row": "Row_1lc6qli"
      },
      "description": "Enter the last 4 digits shown on your card",
      "conditional": {
        "hide": "=\"paymentMethod != \\\"card\\\"\""
      }
    },
    {
      "label": "Trade Card Number",
      "type": "textfield",
      "id": "tradeCardNumber",
      "key": "tradeCardNumber",
      "validate": {
        "required": false
      },
      "layout": {
        "row": "Row_03ke60p"
      },
      "conditional": {
        "hide": "={\"hide\": \"=paymentMethod != \\\"finance\\\"\"}"
      },
      "description": "Enter Trade Card Number"
    },
    {
      "text": "### Finance Payment Details\nInterest-free finance is available to Trade Card members only. Please confirm your repayment preference below.",
      "type": "text",
      "layout": {
        "row": "Row_1lt45x8",
        "columns": null
      },
      "id": "Field_1lyihxb"
    },
    {
      "label": "Repayment Period",
      "values": [
        {
          "label": "6 Months",
          "value": "6"
        },
        {
          "label": "12 Months",
          "value": "12"
        }
      ],
      "type": "radio",
      "layout": {
        "row": "Row_1lvdmkd",
        "columns": null
      },
      "id": "Field_0d26qit",
      "key": "repaymentPeriod",
      "validate": {
        "required": true
      }
    },
    {
      "label": "I confirm I am applying for interest-free finance and agree to the repayment schedule",
      "type": "checkbox",
      "layout": {
        "row": "Row_098dezl",
        "columns": null
      },
      "id": "Field_1l0pduu",
      "key": "financeConfirmed",
      "validate": {
        "required": true
      }
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.44.0"
  },
  "schemaVersion": 19,
  "id": "get-payment-details",
  "versionTag": "1",
  "type": "default"
}