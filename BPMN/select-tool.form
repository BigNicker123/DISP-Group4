{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.45.0"
  },
  "schemaVersion": 19,
  "id": "select-tool",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_select_tool",
      "text": "## Select Tools\nChoose whether you would like to purchase or hire, then select the tools you need from our available stock."
    },
    {
      "label": "Purchase or Hire?",
      "values": [
        {
          "label": "Purchase",
          "value": "purchase"
        },
        {
          "label": "Hire",
          "value": "hire"
        }
      ],
      "type": "radio",
      "id": "Field_1szsm5e",
      "key": "purchaseOrHire",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Select Tools / Materials",
      "description": "Only tools currently in stock are shown.",
      "valuesExpression": "=availableTools",
      "type": "taglist",
      "id": "Field_1f29fl0",
      "key": "selectedTools",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Quantity",
      "type": "number",
      "id": "Field_19eipax",
      "key": "quantity",
      "validate": {
        "required": true,
        "min": 1,
        "max": 100
      },
      "decimalDigits": 0
    }
  ]
}
