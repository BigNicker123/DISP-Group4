{
  "components": [
    {
      "text": "## Select Tools\nChoose whether you would like to purchase or hire, then select the tools you need from our available stock.",
      "type": "text",
      "id": "title_select_tool",
      "layout": {
        "row": "Row_0nob5n7"
      }
    },
    {
      "text": "⚠️ **Sorry, the tool(s) you selected are not available in the quantity requested.** Please adjust your selection, quantity, or dates and try again.",
      "type": "text",
      "layout": {
        "row": "Row_0bsunlt",
        "columns": null
      },
      "id": "Field_0te7zsr",
      "conditional": {
        "hide": "=not(toolAvailable = false)"
      }
    },
    {
      "label": "Purchase or Hire?",
      "values": [
        {
          "label": "Purchase",
          "value": "purchase"
        },
        {
          "label": "Hire",
          "value": "hire"
        }
      ],
      "type": "radio",
      "id": "Field_1szsm5e",
      "key": "purchaseOrHire",
      "validate": {
        "required": true
      },
      "layout": {
        "row": "Row_0aue1kp"
      }
    },
    {
      "text": "#### Tool Selection",
      "type": "text",
      "id": "section_tool_selection"
    },
    {
      "label": "Select Tools / Materials",
      "description": "Only tools currently in stock are shown.",
      "valuesExpression": "=availableTools",
      "type": "taglist",
      "id": "Field_1f29fl0",
      "key": "selectedTools",
      "validate": {
        "required": true
      },
      "layout": {
        "row": "Row_1wf6um5"
      }
    },
    {
      "label": "Quantity",
      "type": "number",
      "id": "Field_19eipax",
      "key": "quantity",
      "validate": {
        "required": true,
        "min": 1,
        "max": 100
      },
      "decimalDigits": 0,
      "layout": {
        "row": "Row_14jv847"
      }
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.45.0"
  },
  "schemaVersion": 19,
  "id": "select-tool",
  "type": "default"
}