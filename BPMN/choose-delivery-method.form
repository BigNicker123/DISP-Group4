{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "choose-delivery-method",
  "versionTag": "3",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_delivery",
      "text": "## Delivery Method\nChoose how you would like to receive your order."
    },
    {
      "type": "radio",
      "id": "deliveryMethod",
      "key": "deliveryMethod",
      "label": "Delivery Method",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Home Delivery",
          "value": "delivery"
        },
        {
          "label": "Click and Collect",
          "value": "click-and-collect"
        }
      ]
    },
    {
      "type": "textarea",
      "id": "deliveryAddress",
      "key": "deliveryAddress",
      "label": "Delivery Address",
      "description": "Enter the full address where the order should be delivered.",
      "validate": {
        "required": true,
        "minLength": 10
      },
      "conditional": {
        "hide": "=deliveryMethod != \"delivery\""
      }
    },
    {
      "type": "textfield",
      "id": "deliveryNotes",
      "key": "deliveryNotes",
      "label": "Delivery Instructions / Notes",
      "description": "e.g. leave at rear gate, call on arrival.",
      "validate": {
        "required": false
      },
      "conditional": {
        "hide": "=deliveryMethod != \"delivery\""
      }
    }
  ]
}
