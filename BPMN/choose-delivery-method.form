{
  "components": [
    {
      "label": "Choose Delivery Method",
      "values": [
        {
          "label": "Home Delivery",
          "value": "delivery"
        },
        {
          "label": "Click and Collect",
          "value": "click-and-collect"
        }
      ],
      "type": "radio",
      "id": "deliveryMethod",
      "key": "deliveryMethod",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Delivery Address (if Home Delivery)",
      "type": "textarea",
      "id": "deliveryAddress",
      "key": "deliveryAddress",
      "validate": {
        "required": false
      },
      "conditional": {
        "hide": "=\"deliveryMethod != \\\"delivery\\\"\""
      }
    },
    {
      "label": "Delivery Instructions / Notes",
      "type": "textfield",
      "id": "deliveryNotes",
      "key": "deliveryNotes",
      "validate": {
        "required": false
      }
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.44.0"
  },
  "schemaVersion": 19,
  "id": "choose-delivery-method",
  "versionTag": "1",
  "type": "default"
}