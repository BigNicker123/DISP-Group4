{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "inspect-tool-handover",
  "versionTag": "3",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_inspect",
      "text": "## Tool Return Inspection\nComplete this checklist when a hired tool is returned. All fields are required before the tool can be returned to stock."
    },
    {
      "type": "text",
      "id": "section_tool_id",
      "text": "#### Tool Identification"
    },
    {
      "type": "textfield",
      "id": "bookingRef_display",
      "key": "bookingReference",
      "label": "Booking Reference",
      "disabled": true
    },
    {
      "type": "textfield",
      "id": "selectedTools_display",
      "key": "selectedTools",
      "label": "Tool(s) Hired",
      "disabled": true
    },
    {
      "type": "number",
      "id": "quantity_display",
      "key": "quantity",
      "label": "Quantity",
      "disabled": true
    },
    {
      "type": "text",
      "id": "section_condition",
      "text": "#### Condition Assessment"
    },
    {
      "type": "select",
      "id": "toolCondition",
      "key": "toolCondition",
      "label": "Tool Condition on Return",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Good – No Issues",
          "value": "good"
        },
        {
          "label": "Minor Wear – Routine Service Needed",
          "value": "minor-wear"
        },
        {
          "label": "Damaged – Repair Required",
          "value": "damaged"
        },
        {
          "label": "Beyond Repair – Decommission",
          "value": "decommission"
        }
      ]
    },
    {
      "type": "textarea",
      "id": "faultDescription",
      "key": "faultDescription",
      "label": "Fault Description",
      "description": "Describe the fault in detail so FixPro can assess the repair.",
      "validate": {
        "required": true,
        "minLength": 10
      },
      "conditional": {
        "hide": "=toolCondition = \"good\" or toolCondition = \"minor-wear\""
      }
    },
    {
      "type": "select",
      "id": "serviceType",
      "key": "serviceType",
      "label": "Expected Service Type",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Routine Maintenance",
          "value": "routine"
        },
        {
          "label": "Repair",
          "value": "repair"
        },
        {
          "label": "Out-of-Service / Decommission",
          "value": "decommission"
        }
      ]
    },
    {
      "type": "number",
      "id": "repairCost",
      "key": "repairCost",
      "label": "Estimated Repair Cost (£)",
      "validate": {
        "required": true,
        "min": 0
      },
      "conditional": {
        "hide": "=serviceType != \"repair\""
      }
    },
    {
      "type": "text",
      "id": "section_signoff",
      "text": "#### Sign-Off"
    },
    {
      "type": "checkbox",
      "id": "handoverSigned",
      "key": "handoverSigned",
      "label": "Digital Handover Checklist Signed Off",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "id": "supervisorName",
      "key": "supervisorName",
      "label": "Warehouse Supervisor Name",
      "validate": {
        "required": true,
        "minLength": 2
      }
    }
  ]
}
