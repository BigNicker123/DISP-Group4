{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "select-delivery-time",
  "versionTag": "2",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_delivery_time",
      "text": "## Select Delivery Time\nChoose your preferred delivery date and time slot, and confirm who will be available to receive the order."
    },
    {
      "type": "datetime",
      "id": "preferredDeliveryDate",
      "key": "preferredDeliveryDate",
      "label": "Preferred Delivery Date",
      "subtype": "date",
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "id": "preferredDeliverySlot",
      "key": "preferredDeliverySlot",
      "label": "Preferred Delivery Time Slot",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Morning (08:00 – 12:00)",
          "value": "morning"
        },
        {
          "label": "Afternoon (12:00 – 17:00)",
          "value": "afternoon"
        },
        {
          "label": "Evening (17:00 – 20:00)",
          "value": "evening"
        }
      ]
    },
    {
      "type": "text",
      "id": "section_contact",
      "text": "#### Delivery Contact\nIf you will be at home to receive the delivery, your name and phone number will be pre-filled below."
    },
    {
      "type": "textfield",
      "id": "deliveryContactName",
      "key": "deliveryContactName",
      "label": "Delivery Contact Name",
      "description": "Name of the person who will receive the delivery.",
      "validate": {
        "required": true,
        "minLength": 2
      }
    },
    {
      "type": "textfield",
      "id": "deliveryContactPhone",
      "key": "deliveryContactPhone",
      "label": "Delivery Contact Phone",
      "description": "UK format — numbers, spaces, hyphens and + only.",
      "validate": {
        "required": true,
        "minLength": 10,
        "maxLength": 15,
        "pattern": "^[0-9+\\s\\-()]{10,15}$"
      }
    }
  ]
}
