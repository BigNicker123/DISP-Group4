{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "pay-probuild-amount",
  "versionTag": "2",
  "type": "default",
  "components": [
    {
      "type": "text",
      "id": "title_pay_probuild",
      "text": "## Finance Repayment Agreement\nYour credit application has been approved by FinTrust UK. Please review the terms below and confirm your repayment preference."
    },
    {
      "type": "number",
      "id": "financeAmount",
      "key": "financeAmount",
      "label": "Finance Amount Approved (£)",
      "disabled": true,
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "id": "repaymentPeriod",
      "key": "repaymentPeriod",
      "label": "Repayment Period",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "6 Months",
          "value": "6"
        },
        {
          "label": "12 Months",
          "value": "12"
        }
      ]
    },
    {
      "type": "textfield",
      "id": "bankAccountRef",
      "key": "bankAccountRef",
      "label": "Bank Account Reference",
      "description": "Enter your sort code and account number (e.g. 12-34-56 / 12345678).",
      "validate": {
        "required": true
      }
    },
    {
      "type": "checkbox",
      "id": "repaymentAgreed",
      "key": "repaymentAgreed",
      "label": "I agree to the repayment schedule set by FinTrust UK",
      "validate": {
        "required": true
      }
    }
  ]
}
