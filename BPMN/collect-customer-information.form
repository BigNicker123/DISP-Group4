{
  "components": [
    {
      "label": "First Name",
      "type": "textfield",
      "id": "customerFirstName",
      "key": "customerFirstName",
      "validate": {
        "required": true,
        "minLength": "2"
      }
    },
    {
      "label": "Last Name",
      "type": "textfield",
      "id": "customerLastName",
      "key": "customerLastName",
      "validate": {
        "required": true,
        "minLength": "2"
      }
    },
    {
      "label": "Email Address",
      "type": "textfield",
      "id": "customerEmail",
      "key": "customerEmail",
      "validate": {
        "required": true,
        "validationType": "email"
      },
      "description": "Please enter a valid email address",
      "properties": {}
    },
    {
      "label": "Phone Number",
      "type": "textfield",
      "id": "customerPhone",
      "key": "customerPhone",
      "validate": {
        "required": true,
        "validationType": "phone"
      },
      "description": "Please enter a valid UK phone number"
    },
    {
      "label": "Delivery Address",
      "type": "textarea",
      "id": "customerAddress",
      "key": "customerAddress",
      "validate": {
        "required": false
      }
    },
    {
      "label": "Trade Card Member?",
      "type": "checkbox",
      "id": "isTradeCardMember",
      "key": "isTradeCardMember"
    }
  ],
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.44.0"
  },
  "schemaVersion": 19,
  "id": "collect-customer-information",
  "versionTag": "1",
  "type": "default"
}