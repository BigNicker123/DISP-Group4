{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "collect-customer-information",
  "versionTag": "1",
  "type": "default",
  "components": [
    {
      "type": "textfield",
      "id": "customerFirstName",
      "key": "customerFirstName",
      "label": "First Name",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "id": "customerLastName",
      "key": "customerLastName",
      "label": "Last Name",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "id": "customerEmail",
      "key": "customerEmail",
      "label": "Email Address",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textfield",
      "id": "customerPhone",
      "key": "customerPhone",
      "label": "Phone Number",
      "validate": {
        "required": true
      }
    },
    {
      "type": "textarea",
      "id": "customerAddress",
      "key": "customerAddress",
      "label": "Delivery Address",
      "validate": {
        "required": false
      }
    },
    {
      "type": "checkbox",
      "id": "isTradeCardMember",
      "key": "isTradeCardMember",
      "label": "Trade Card Member?"
    }
  ]
}