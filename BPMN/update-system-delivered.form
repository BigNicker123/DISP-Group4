{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "e103445"
  },
  "schemaVersion": 16,
  "id": "update-system-delivered",
  "versionTag": "1",
  "type": "default",
  "components": [
    {
      "type": "textfield",
      "id": "orderId",
      "key": "orderId",
      "label": "Order ID",
      "validate": {
        "required": true
      },
      "disabled": true
    },
    {
      "type": "datetime",
      "id": "actualDeliveryDate",
      "key": "actualDeliveryDate",
      "label": "Actual Delivery Date & Time",
      "subtype": "datetime",
      "validate": {
        "required": true
      }
    },
    {
      "type": "select",
      "id": "deliveryStatus",
      "key": "deliveryStatus",
      "label": "Delivery Status",
      "validate": {
        "required": true
      },
      "values": [
        {
          "label": "Delivered Successfully",
          "value": "delivered"
        },
        {
          "label": "Partially Delivered",
          "value": "partial"
        },
        {
          "label": "Failed – Customer Not Available",
          "value": "failed-not-available"
        },
        {
          "label": "Failed – Damaged in Transit",
          "value": "failed-damaged"
        }
      ]
    },
    {
      "type": "textfield",
      "id": "receivedBy",
      "key": "receivedBy",
      "label": "Received By (Customer Name)",
      "validate": {
        "required": false
      }
    },
    {
      "type": "textarea",
      "id": "deliveryNotes",
      "key": "deliveryNotes",
      "label": "Delivery Notes",
      "validate": {
        "required": false
      }
    }
  ]
}